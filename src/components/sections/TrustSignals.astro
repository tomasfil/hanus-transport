---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";

const signals = [
  {
    title: "GPS sledování",
    description: "Všechna vozidla jsou vybavena GPS modulem. Vždy přesně víte, kde se vaše zásilka nachází.",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
  },
  {
    title: "Pojištění zásilek",
    description: "Každá zásilka je pojištěna od nakládky přes přepravu až po předání na místě určení.",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  },
  {
    title: "Hydraulické plošiny",
    description: "Na všech vozidlech. Nosnost 750 až 1 500 kg. Snadná manipulace bez dalšího vybavení.",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-7.5L16.5 3m0 0L12 7.5M16.5 3v13.5" /></svg>`,
  },
  {
    title: "15+ let zkušeností",
    description: "Začali jsme jako OSVČ v roce 2011. Od roku 2017 fungujeme jako Hanuš Transport s.r.o.",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];
---

<section class="bg-gray-50 py-16 lg:py-24">
  <Container>
    <SectionHeading subtitle="Proč zákazníci volí Hanuš Transport pro přepravu zboží.">
      Proč právě my
    </SectionHeading>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {signals.map((signal) => (
        <div class="text-center">
          <div class="mx-auto flex size-16 items-center justify-center rounded-2xl bg-orange-100 text-orange-600" set:html={signal.icon} />
          <h3 class="mt-4 text-lg font-bold text-navy-900">{signal.title}</h3>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">{signal.description}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
