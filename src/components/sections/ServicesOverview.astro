---
import Container from "@components/ui/Container.astro";
import Card from "@components/ui/Card.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";

const services = [
  {
    title: "Nákladní autodoprava",
    description: "Přeprava zboží po celé ČR vozidly od 3,5 do 12 tun. GPS sledování, pojištění zásilek.",
    href: "/sluzby/nakladni-autodoprava/",
    icon: `<svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="14" height="12" rx="1" /><path d="M15 8h3l3 4v4h-6V8z" /><circle cx="6" cy="18" r="2" /><circle cx="18" cy="18" r="2" /><path d="M8 16h7M1 16h3" /></svg>`,
  },
  {
    title: "Přeprava stavebnin",
    description: "Stavební materiály s hydraulickými plošinami do 1 500 kg. Přímé doručení na stavbu.",
    href: "/sluzby/preprava-stavebnin/",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 20h16M4 20V10l4-6h8l4 6v10M4 20h4m8 0h4M8 20v-4h8v4M9 10h6" /></svg>`,
  },
  {
    title: "Přeprava palet",
    description: "Kapacita až 18 europalet na jízdu. Kompletní vybavení — paletové vozíky, upínací popruhy.",
    href: "/sluzby/preprava-palet/",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21H4M20 21V8l-3-3H7L4 8v13M8 17v4M12 17v4M16 17v4M6 13h12M6 9h12" /></svg>`,
  },
  {
    title: "Svoz elektrospotřebičů",
    description: "Pravidelný svoz použitých spotřebičů od prodejců a sběrných dvorů ve Středočeském kraji.",
    href: "/sluzby/svoz-elektrospotrebicu/",
    icon: `<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>`,
  },
];
---

<section class="py-16 lg:py-24">
  <Container>
    <SectionHeading subtitle="Specializujeme se na přepravu zboží, stavebnin a palet po celé České republice.">
      Naše služby
    </SectionHeading>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <Card href={service.href}>
          <div class="text-orange-500 mb-4" set:html={service.icon} />
          <h3 class="text-lg font-bold text-navy-900">{service.title}</h3>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">{service.description}</p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-orange-600">
            Zjistit více
            <svg class="ml-1 size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </Card>
      ))}
    </div>
  </Container>
</section>
