---
interface Props {
  subtitle?: string;
  centered?: boolean;
  class?: string;
}

const { subtitle, centered = true, class: className = "" } = Astro.props;
---

<div class:list={[centered && "text-center", "mb-12", className]}>
  <h2 class="text-3xl font-bold text-navy-900 sm:text-4xl">
    <slot />
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-navy-600 max-w-2xl" class:list={[centered && "mx-auto"]}>
      {subtitle}
    </p>
  )}
</div>
