---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline";
  size?: "sm" | "md" | "lg";
  class?: string;
  type?: "button" | "submit";
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  type = "button",
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2";

const variantClasses = {
  primary: "bg-orange-500 text-white hover:bg-orange-600 focus:ring-orange-500",
  secondary: "bg-navy-700 text-white hover:bg-navy-800 focus:ring-navy-700",
  outline: "border-2 border-navy-700 text-navy-700 hover:bg-navy-50 focus:ring-navy-700",
};

const sizeClasses = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-base",
  lg: "px-8 py-4 text-lg",
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
const Tag = href ? "a" : "button";
---

<Tag class={classes} {...(href ? { href } : { type })}>
  <slot />
</Tag>
