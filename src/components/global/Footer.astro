---
import { SITE, COMPANY } from "@lib/constants";
import { footerNavigation } from "@lib/navigation";
---

<footer class="bg-navy-900 text-navy-200">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Company info -->
      <div>
        <a href="/" class="text-xl font-bold text-white">
          <span class="text-orange-400">Hanuš</span> Transport
        </a>
        <p class="mt-4 text-sm leading-relaxed">
          Autodoprava a přeprava zboží po celé ČR od roku 2011. Sídlíme ve Slaném.
        </p>
        <div class="mt-4 space-y-1 text-sm">
          <p>IČO: {COMPANY.ico}</p>
          <p>DIČ: {COMPANY.dic}</p>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Služby</h3>
        <ul class="mt-4 space-y-3">
          {footerNavigation.services.map((item) => (
            <li><a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Společnost</h3>
        <ul class="mt-4 space-y-3">
          {footerNavigation.company.map((item) => (
            <li><a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Kontakt</h3>
        <ul class="mt-4 space-y-3">
          <li class="flex items-center gap-2 text-sm">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${COMPANY.contacts.martinHanus.phone.replace(/\s/g, "")}`} class="hover:text-white transition-colors">{COMPANY.contacts.martinHanus.phone}</a>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${COMPANY.email}`} class="hover:text-white transition-colors">{COMPANY.email}</a>
          </li>
          <li class="flex items-start gap-2 text-sm">
            <svg class="size-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{COMPANY.operationalBase}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-navy-800 pt-8">
      <div class="flex flex-col items-center gap-4 text-center text-sm text-navy-400 sm:flex-row sm:justify-between sm:text-left">
        <p>&copy; {new Date().getFullYear()} {COMPANY.name}. Všechna práva vyhrazena.</p>
        <p>
          Web vytvořil{" "}
          <a href={`mailto:${SITE.authorEmail}`} class="text-navy-300 hover:text-white transition-colors">{SITE.author}</a>
          {" "}— IČO {SITE.authorIco}, {SITE.authorAddress}
        </p>
      </div>
    </div>
  </div>
</footer>
