---
import { mainNavigation } from "@lib/navigation";

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/logo.svg" alt="Hanuš Transport logo" class="h-14 w-auto lg:h-16" width="80" height="56" />
        <span class="text-lg font-bold lg:text-xl">
          <span class="text-orange-500">Hanuš</span>
          <span class="text-navy-900"> Transport</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex lg:items-center lg:gap-1" aria-label="Hlavní navigace">
        {mainNavigation.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class:list={[
                "inline-flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "text-orange-600 bg-orange-50"
                  : "text-navy-700 hover:text-navy-900 hover:bg-gray-50",
              ]}
            >
              {item.label}
              {item.children && (
                <svg class="size-4 text-navy-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full z-50 w-64 rounded-xl bg-white p-2 shadow-lg ring-1 ring-gray-100 opacity-0 transition-all group-hover:visible group-hover:opacity-100">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      "block rounded-lg px-4 py-2.5 text-sm transition-colors",
                      isActive(child.href)
                        ? "text-orange-600 bg-orange-50"
                        : "text-navy-700 hover:bg-gray-50 hover:text-navy-900",
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <a
        href="/cenik/"
        class="hidden lg:inline-flex items-center rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-orange-600"
      >
        Poptávka
      </a>

      <!-- Mobile menu toggle -->
      <label for="mobile-menu-toggle" class="lg:hidden cursor-pointer rounded-lg p-2 hover:bg-gray-50" aria-label="Otevřít menu">
        <svg class="size-6 text-navy-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Mobile menu: CSS-only toggle via hidden checkbox + peer selector.
       Avoids any client-side JS for static output compliance. -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" />
  <div class="hidden peer-checked:block lg:hidden border-t border-gray-100 bg-white">
    <nav class="mx-auto max-w-7xl px-4 py-4 sm:px-6" aria-label="Mobilní navigace">
      {mainNavigation.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              "block rounded-lg px-4 py-3 text-base font-medium transition-colors",
              isActive(item.href)
                ? "text-orange-600 bg-orange-50"
                : "text-navy-700 hover:bg-gray-50",
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="ml-4 border-l-2 border-gray-100 pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    "block rounded-lg px-4 py-2 text-sm transition-colors",
                    isActive(child.href)
                      ? "text-orange-600"
                      : "text-navy-600 hover:text-navy-900",
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="mt-4 pt-4 border-t border-gray-100">
        <a
          href="/cenik/"
          class="block rounded-lg bg-orange-500 px-4 py-3 text-center text-base font-semibold text-white hover:bg-orange-600"
        >
          Poptávka
        </a>
      </div>
    </nav>
  </div>
</header>
