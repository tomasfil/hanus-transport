---
// Generic JSON-LD injector — accepts any schema object from lib/schema-org.ts
// and renders it as a <script type="application/ld+json"> tag in the page head.
interface Props {
  schema: Record<string, unknown>;
}

const { schema } = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
