---
import PageLayout from "./PageLayout.astro";
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";

interface Props {
  title: string;
  description: string;
  headline: string;
  publishedDate: Date;
  readingTime: number;
  breadcrumbs: Array<{ label: string; href?: string }>;
}

const { title, description, headline, publishedDate, readingTime, breadcrumbs } = Astro.props;

const formattedDate = publishedDate.toLocaleDateString("cs-CZ", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<PageLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <slot name="structured-data" slot="structured-data" />

  <article>
    <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
      <Container>
        <div class="max-w-3xl">
          <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
            {headline}
          </h1>
          <div class="mt-4 flex items-center gap-4 text-sm text-navy-300">
            <time datetime={publishedDate.toISOString().split("T")[0]}>{formattedDate}</time>
            <span>·</span>
            <span>{readingTime} min čtení</span>
          </div>
        </div>
      </Container>
    </section>

    <section class="py-12 lg:py-16">
      <Container>
        <div class="max-w-3xl mx-auto prose prose-navy prose-headings:text-navy-900 prose-a:text-orange-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-navy-800">
          <slot />
        </div>
      </Container>
    </section>

    <section class="bg-navy-900 py-12 lg:py-16">
      <Container>
        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-white sm:text-3xl">Máte dotaz k přepravě?</h2>
          <p class="mt-4 text-navy-200">
            Rádi vám poradíme. Kontaktujte nás telefonicky nebo přes poptávkový formulář.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <Button href="/cenik/" variant="primary" size="lg">Poptávkový formulář</Button>
            <Button href="/casto-kladene-dotazy/" variant="outline" size="lg" class="border-white text-white hover:bg-white/10">Časté dotazy</Button>
          </div>
        </div>
      </Container>
    </section>
  </article>
</PageLayout>
