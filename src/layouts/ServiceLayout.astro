---
import PageLayout from "./PageLayout.astro";
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";

interface Props {
  title: string;
  description: string;
  headline: string;
  heroImage?: string;
  breadcrumbs: Array<{ label: string; href?: string }>;
}

const { title, description, headline, heroImage, breadcrumbs } = Astro.props;
---

<PageLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <slot name="structured-data" slot="structured-data" />

  <article>
    <section class="relative">
      {heroImage ? (
        <>
          <div class="absolute inset-0">
            <img src={heroImage} alt="" class="size-full object-cover" width="1200" height="675" aria-hidden="true" />
            <div class="absolute inset-0 bg-navy-900/75"></div>
          </div>
          <Container>
            <div class="relative py-16 lg:py-20">
              <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
                {headline}
              </h1>
            </div>
          </Container>
        </>
      ) : (
        <div class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
          <Container>
            <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
              {headline}
            </h1>
          </Container>
        </div>
      )}
    </section>

    <section class="py-12 lg:py-16">
      <Container>
        <div class="max-w-3xl mx-auto prose prose-navy prose-headings:text-navy-900 prose-a:text-orange-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-navy-800">
          <slot />
        </div>
      </Container>
    </section>

    <section class="bg-orange-50 py-12 lg:py-16">
      <Container>
        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Potřebujete přepravu?</h2>
          <p class="mt-4 text-navy-600">
            Kontaktujte nás pro nezávaznou cenovou nabídku. Rádi vám navrhneme řešení na míru.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <Button href="/cenik/" variant="primary" size="lg">Poptávkový formulář</Button>
            <Button href="tel:+420725961978" variant="outline" size="lg">+420 725 961 978</Button>
          </div>
        </div>
      </Container>
    </section>
  </article>
</PageLayout>
