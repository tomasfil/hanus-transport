---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import FleetCard from "@components/sections/FleetCard.astro";
import Button from "@components/ui/Button.astro";
import { getCollection } from "astro:content";

const vehicles = (await getCollection("vehicles")).sort((a, b) => a.data.order - b.data.order);

const breadcrumbs = [
  { label: "Úvod", href: "/" },
  { label: "Vozový park" },
];
---

<PageLayout
  title="Vozový park — 6 vozidel do 12 tun"
  description="Vozový park Hanuš Transport — 6 vozidel od dodávek po nákladní auta do 12 tun. Všechna vybavena hydraulickými plošinami 750–1500 kg a GPS sledováním."
  breadcrumbs={breadcrumbs}
>
  <section class="relative">
    <div class="absolute inset-0">
      <img
        src="/images/fleet/flotila.webp"
        alt="Flotila vozidel Hanuš Transport"
        class="size-full object-cover"
        width="1200"
        height="675"
      />
      <div class="absolute inset-0 bg-navy-900/75"></div>
    </div>
    <Container>
      <div class="relative py-20 lg:py-28">
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
          Vozový park
        </h1>
        <p class="mt-4 text-lg text-navy-200 max-w-2xl">
          Disponujeme 6&nbsp;vozidly od dodávek po nákladní automobily s&nbsp;celkovou hmotností do&nbsp;12&nbsp;tun.
          Všechna vozidla jsou vybavena hydraulickými plošinami pro snadnou nakládku a&nbsp;vykládku.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-12 lg:py-16">
    <Container>
      <h2 class="sr-only">Přehled vozidel</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {vehicles.map((vehicle) => (
          <FleetCard {...vehicle.data} />
        ))}
      </div>
    </Container>
  </section>

  <section class="bg-gray-50 py-12 lg:py-16">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Standardní vybavení všech vozidel</h2>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-3">
            <svg class="size-5 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-navy-700">Hydraulická plošina (750–1 500 kg) pro snadnou nakládku a vykládku</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-navy-700">Plachtový nástavek — ochrana nákladu před počasím</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-navy-700">Paletový vozík a rudlík pro manipulaci</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-navy-700">GPS modul pro sledování polohy zásilky</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-navy-700">Upínací popruhy pro zajištění nákladu</span>
          </li>
        </ul>
      </div>
    </Container>
  </section>

  <section class="py-12 lg:py-16">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Naše služby</h2>
        <p class="mt-4 text-navy-600">Vozidla z našeho parku nasazujeme podle typu zásilky a požadavků na přepravu.</p>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          <li><a href="/sluzby/nakladni-autodoprava/" class="flex items-center gap-2 rounded-lg border border-gray-100 px-4 py-3 text-sm font-medium text-navy-700 hover:bg-gray-50 hover:text-orange-600 transition-colors">Nákladní autodoprava</a></li>
          <li><a href="/sluzby/preprava-stavebnin/" class="flex items-center gap-2 rounded-lg border border-gray-100 px-4 py-3 text-sm font-medium text-navy-700 hover:bg-gray-50 hover:text-orange-600 transition-colors">Přeprava stavebnin</a></li>
          <li><a href="/sluzby/preprava-palet/" class="flex items-center gap-2 rounded-lg border border-gray-100 px-4 py-3 text-sm font-medium text-navy-700 hover:bg-gray-50 hover:text-orange-600 transition-colors">Přeprava palet</a></li>
          <li><a href="/sluzby/svoz-elektrospotrebicu/" class="flex items-center gap-2 rounded-lg border border-gray-100 px-4 py-3 text-sm font-medium text-navy-700 hover:bg-gray-50 hover:text-orange-600 transition-colors">Svoz elektrospotřebičů</a></li>
        </ul>
      </div>
    </Container>
  </section>

  <section class="bg-orange-50 py-12 lg:py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Potřebujete přepravu?</h2>
        <p class="mt-4 text-navy-600">Vybereme vhodné vozidlo pro vaši zásilku. Kontaktujte nás pro cenovou nabídku.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <Button href="/cenik/" variant="primary" size="lg">Poptávkový formulář</Button>
          <Button href="tel:+420725961978" variant="outline" size="lg">+420 725 961 978</Button>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
