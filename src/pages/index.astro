---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/sections/Hero.astro";
import ServicesOverview from "@components/sections/ServicesOverview.astro";
import TrustSignals from "@components/sections/TrustSignals.astro";
import RegionCoverage from "@components/sections/RegionCoverage.astro";
import FAQSection from "@components/sections/FAQSection.astro";
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import Button from "@components/ui/Button.astro";
import TransportCompanySchema from "@components/seo/TransportCompanySchema.astro";
import FAQSchema from "@components/seo/FAQSchema.astro";
import faqData from "@data/faq.json";

const homeFaq = faqData.filter(q => ["oblast-pusobnosti", "typy-vozidel", "pojisteni", "gps-sledovani", "jak-objednat"].includes(q.id));
---

<PageLayout
  title="Autodoprava a přeprava zboží po celé ČR"
  description="Autodoprava a přeprava zboží po celé ČR. Nákladní doprava do 12 tun, přeprava stavebnin, palet a svoz elektrospotřebičů. Hanuš Transport — ze Slaného od 2011."
>
  <TransportCompanySchema slot="structured-data" />
  <FAQSchema slot="structured-data" items={homeFaq} />

  <Hero />
  <ServicesOverview />
  <TrustSignals />
  <RegionCoverage />

  <!-- Homepage FAQ teaser -->
  <section class="py-16 lg:py-24">
    <Container>
      <SectionHeading subtitle="Odpovědi na nejčastější otázky o naší autodopravě.">
        Časté dotazy
      </SectionHeading>
      <div class="max-w-3xl mx-auto">
        <FAQSection items={homeFaq} />
        <div class="mt-8 text-center">
          <Button href="/casto-kladene-dotazy/" variant="outline">
            Všechny dotazy
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Final CTA -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Potřebujete přepravu?</h2>
        <p class="mt-4 text-lg text-navy-200">
          Kontaktujte nás pro nezávaznou cenovou nabídku.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <Button href="/cenik/" variant="primary" size="lg">
            Nezávazná poptávka
          </Button>
          <Button href="tel:+420725961978" variant="outline" size="lg" class="border-white text-white hover:bg-white/10">
            +420 725 961 978
          </Button>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
