---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import ContactForm from "@components/sections/ContactForm.astro";
import Button from "@components/ui/Button.astro";

const breadcrumbs = [
  { label: "Úvod", href: "/" },
  { label: "Ceník a poptávka" },
];
---

<PageLayout
  title="Ceník a poptávka přepravy"
  description="Poptejte přepravu zboží od Hanuš Transport. Ceny na míru podle typu zásilky, vzdálenosti a požadavků. Odpovíme do 24 hodin."
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
    <Container>
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Ceník a poptávka
      </h1>
      <p class="mt-4 text-lg text-navy-200 max-w-2xl">
        Ceny nejsou pevně dané — vždy se s&nbsp;vámi rádi domluvíme,
        abychom vám navrhli řešení na míru.
      </p>
    </Container>
  </section>

  <section class="py-12 lg:py-16">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Form -->
        <div>
          <h2 class="text-2xl font-bold text-navy-900 mb-6">Poptávkový formulář</h2>
          <ContactForm />
        </div>

        <!-- Info sidebar -->
        <div>
          <h2 class="text-2xl font-bold text-navy-900 mb-6">Co ovlivňuje cenu</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-orange-100 text-orange-600 font-bold">1</div>
              <div>
                <h3 class="font-semibold text-navy-900">Vzdálenost</h3>
                <p class="mt-1 text-sm text-navy-600">Počet kilometrů včetně příjezdu na místo nakládky.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-orange-100 text-orange-600 font-bold">2</div>
              <div>
                <h3 class="font-semibold text-navy-900">Hmotnost a objem</h3>
                <p class="mt-1 text-sm text-navy-600">Typ a velikost zásilky určuje potřebné vozidlo.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-orange-100 text-orange-600 font-bold">3</div>
              <div>
                <h3 class="font-semibold text-navy-900">Typ nákladu</h3>
                <p class="mt-1 text-sm text-navy-600">Stavební materiály, palety, elektrospotřebiče — různé požadavky na manipulaci.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-orange-100 text-orange-600 font-bold">4</div>
              <div>
                <h3 class="font-semibold text-navy-900">Termín</h3>
                <p class="mt-1 text-sm text-navy-600">Standardní (2–5 dní), expresní (do 24h), víkendová přeprava.</p>
              </div>
            </div>
          </div>

          <div class="mt-8 rounded-2xl bg-navy-50 p-6">
            <h3 class="font-semibold text-navy-900">Raději zavoláte?</h3>
            <p class="mt-2 text-sm text-navy-600">Rádi vám poradíme telefonicky.</p>
            <div class="mt-4 space-y-2">
              <a href="tel:+420725961978" class="flex items-center gap-2 text-sm font-medium text-navy-900 hover:text-orange-600">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +420 725 961 978 — Martin Hanuš
              </a>
              <a href="tel:+420725091376" class="flex items-center gap-2 text-sm font-medium text-navy-900 hover:text-orange-600">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +420 725 091 376 — Pavla Hanušová
              </a>
            </div>
          </div>

          <div class="mt-6">
            <Button href="/pruvodce/jak-se-pocita-cena-prepravy/" variant="outline" size="sm">
              Jak se počítá cena přepravy →
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
