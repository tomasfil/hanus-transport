---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import FAQSection from "@components/sections/FAQSection.astro";
import FAQSchema from "@components/seo/FAQSchema.astro";
import Button from "@components/ui/Button.astro";
import faqData from "@data/faq.json";

const sortedFaq = [...faqData].sort((a, b) => a.order - b.order);

const breadcrumbs = [
  { label: "Úvod", href: "/" },
  { label: "Časté dotazy" },
];
---

<PageLayout
  title="Často kladené dotazy"
  description="Odpovědi na nejčastější dotazy o autodopravě Hanuš Transport. Služby, ceny, pojištění, GPS sledování, vozový park a více."
  breadcrumbs={breadcrumbs}
>
  <FAQSchema slot="structured-data" items={sortedFaq} />

  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
    <Container>
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Často kladené dotazy
      </h1>
      <p class="mt-4 text-lg text-navy-200 max-w-2xl">
        Odpovědi na nejčastější otázky o naší autodopravě, vozovém parku a službách.
      </p>
    </Container>
  </section>

  <section class="py-12 lg:py-16">
    <Container>
      <div class="max-w-3xl mx-auto">
        <FAQSection items={sortedFaq} />
      </div>
    </Container>
  </section>

  <section class="bg-orange-50 py-12 lg:py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Nenašli jste odpověď?</h2>
        <p class="mt-4 text-navy-600">Kontaktujte nás — rádi vám odpovíme na jakýkoli dotaz.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <Button href="/cenik/" variant="primary" size="lg">Poptávkový formulář</Button>
          <Button href="tel:+420725961978" variant="outline" size="lg">+420 725 961 978</Button>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
