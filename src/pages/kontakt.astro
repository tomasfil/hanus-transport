---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import { COMPANY, SITE } from "@lib/constants";

const breadcrumbs = [
  { label: "Úvod", href: "/" },
  { label: "Kontakt" },
];
---

<PageLayout
  title="Kontakt"
  description="Kontaktujte Hanuš Transport s.r.o. — autodoprava ze Slaného. Telefon, e-mail, IČO 06340199. Martin Hanuš +420 725 961 978."
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-16 lg:py-20">
    <Container>
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Kontakt
      </h1>
      <p class="mt-4 text-lg text-navy-200 max-w-2xl">
        Rádi vám odpovíme na dotazy nebo připravíme cenovou nabídku.
      </p>
    </Container>
  </section>

  <section class="py-12 lg:py-16">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Contact persons -->
        <div>
          <h2 class="text-2xl font-bold text-navy-900 mb-8">Kontaktní osoby</h2>

          <div class="space-y-8">
            <div class="rounded-2xl border border-gray-100 p-6 shadow-sm">
              <h3 class="text-lg font-bold text-navy-900">{COMPANY.contacts.martinHanus.name}</h3>
              <p class="text-sm text-navy-500">{COMPANY.contacts.martinHanus.role}</p>
              <div class="mt-4 space-y-2">
                <a href={`tel:${COMPANY.contacts.martinHanus.phone.replace(/\s/g, "")}`} class="flex items-center gap-2 text-sm text-navy-700 hover:text-orange-600">
                  <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  {COMPANY.contacts.martinHanus.phone}
                </a>
                <a href={`mailto:${COMPANY.contacts.martinHanus.email}`} class="flex items-center gap-2 text-sm text-navy-700 hover:text-orange-600">
                  <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  {COMPANY.contacts.martinHanus.email}
                </a>
              </div>
            </div>

            <div class="rounded-2xl border border-gray-100 p-6 shadow-sm">
              <h3 class="text-lg font-bold text-navy-900">{COMPANY.contacts.pavlaHanusova.name}</h3>
              <p class="text-sm text-navy-500">{COMPANY.contacts.pavlaHanusova.role}</p>
              <div class="mt-4 space-y-2">
                <a href={`tel:${COMPANY.contacts.pavlaHanusova.phone.replace(/\s/g, "")}`} class="flex items-center gap-2 text-sm text-navy-700 hover:text-orange-600">
                  <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  {COMPANY.contacts.pavlaHanusova.phone}
                </a>
                <a href={`mailto:${COMPANY.contacts.pavlaHanusova.email}`} class="flex items-center gap-2 text-sm text-navy-700 hover:text-orange-600">
                  <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  {COMPANY.contacts.pavlaHanusova.email}
                </a>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <a href={`mailto:${COMPANY.email}`} class="flex items-center gap-2 text-sm text-navy-700 hover:text-orange-600">
              <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Obecný e-mail: {COMPANY.email}
            </a>
          </div>
        </div>

        <!-- Company info -->
        <div>
          <h2 class="text-2xl font-bold text-navy-900 mb-8">Fakturační údaje</h2>

          <div class="rounded-2xl bg-gray-50 p-6">
            <dl class="space-y-4">
              <div>
                <dt class="text-sm font-medium text-navy-500">Obchodní název</dt>
                <dd class="mt-1 text-navy-900 font-semibold">{COMPANY.name}</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-navy-500">IČO</dt>
                <dd class="mt-1 text-navy-900 font-semibold">{COMPANY.ico}</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-navy-500">DIČ</dt>
                <dd class="mt-1 text-navy-900 font-semibold">{COMPANY.dic}</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-navy-500">Sídlo</dt>
                <dd class="mt-1 text-navy-900">{COMPANY.address}</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-navy-500">Provozní zázemí</dt>
                <dd class="mt-1 text-navy-900">{COMPANY.operationalBase}</dd>
              </div>
            </dl>
          </div>

          <div class="mt-8 rounded-2xl bg-orange-50 p-6">
            <h3 class="font-semibold text-navy-900">Chcete poptávku?</h3>
            <p class="mt-2 text-sm text-navy-600">Využijte náš poptávkový formulář pro rychlou cenovou nabídku.</p>
            <a href="/cenik/" class="mt-4 inline-flex items-center rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-orange-600">
              Poptávkový formulář
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
